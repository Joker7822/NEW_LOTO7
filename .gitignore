# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Generated pipeline outputs: ignore by default
outputs/*
!outputs/
!outputs/evolution_*.csv
!outputs/evolution_*.json
!outputs/holdout/
!outputs/holdout/*.csv
!outputs/holdout/*.json
!outputs/holdout/*.txt
!outputs/role_ensemble/
!outputs/role_ensemble/*.json
!outputs/role_ensemble/*.txt
!outputs/role_ensemble/*.csv

# Canonical v2 output layout: retain only compact public/state/evidence files
!outputs/production/
!outputs/production/*.csv
!outputs/production/*.txt
!outputs/production/README.md
!outputs/evidence/
!outputs/evidence/**/
!outputs/evidence/**/*.json
!outputs/evidence/**/*.txt
!outputs/evidence/**/*.sha256
!outputs/evidence/README.md
!outputs/state/
!outputs/state/**/
!outputs/state/**/*.json
!outputs/state/README.md
!outputs/diagnostics/
!outputs/diagnostics/**/
!outputs/diagnostics/**/*.json
!outputs/diagnostics/**/*.txt
!outputs/diagnostics/README.md
!outputs/layout_manifest.json
*.log

# Artifact-only diagnostics
outputs/ml_stack/
outputs/complete_ai/
outputs/deep_ai/
outputs/txt_reports/
outputs/diagnostics/**/*.csv

# Deprecated root generated LOTO7 outputs
latest_loto7_prediction.txt
loto7_predictions.csv
loto7_backtest_summary.csv
loto7_backtest_detail.csv
loto7_backtest_report.txt
loto7_backtest_resume.json
loto7_memorybank*.csv

